{
  "name": "agent-md-server",
  "version": "0.1.0",
  "description": "A thin server for rendering Markdown with Mermaid diagrams from configurable directories",
  "type": "module",
  "main": "dist/main.js",
  "bin": {
    "agent-md-server": "dist/main.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/main.ts",
    "start": "node dist/main.js",
    "start:tailscale": "node dist/main.js --tailscale",
    "typecheck": "tsc --noEmit",
    "preflight": "pnpm typecheck && pnpm build",
    "stress": "tsx scripts/stress-renderer.ts"
  },
  "keywords": [
    "mermaid",
    "markdown",
    "server",
    "claude",
    "diagrams"
  ],
  "author": "SemviaIO",
  "license": "MIT",
  "engines": {
    "node": ">=22",
    "pnpm": "10.33.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "fastify": "^5.8.4",
    "playwright": "^1.58.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "minimumReleaseAge": 10080,
    "minimumReleaseAgeExclude": [
      "@semviaio/*"
    ]
  }
}
